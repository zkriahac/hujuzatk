{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "www.hujuzatk.com" }],
      "destination": "https://hujuzatk.com/$1",
      "statusCode": 301
    }
  ],
  "rewrites": [{ "source": "/((?!index.html).*)", "destination": "/index.html" }]
}
