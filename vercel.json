{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.hujuzatk.com" }],
      "destination": "https://hujuzatk.com/:path*",
      "permanent": true
    }
  ],
  "rewrites": [{ "source": "/((?!index.html).*)", "destination": "/index.html" }],
  "crons": [
    { "path": "/api/cron-sync?channel=airbnb",      "schedule": "0 1 * * *" },
    { "path": "/api/cron-sync?channel=gathern",     "schedule": "0 2 * * *" },
    { "path": "/api/cron-sync?channel=booking.com", "schedule": "0 3 * * *" }
  ]
}
