{
  "installCommand": "bun install --no-save",
  "buildCommand": "bun run build",
  "outputDirectory": "dist",
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "www.hujuzatk.com" }],
      "destination": "https://hujuzatk.com/$1",
      "statusCode": 301
    }
  ],
  "rewrites": [
    { "source": "/((?!.*\\.[a-zA-Z0-9]+$|index.html).*)", "destination": "/index.html" }
  ]
}
