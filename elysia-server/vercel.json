{
  "version": 2,
  "buildCommand": "npx prisma generate",
  "builds": [
    { "src": "api/graphql.ts", "use": "@vercel/node" },
    { "src": "api/health.ts", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/graphql", "dest": "/api/graphql.ts" },
    { "src": "/health", "dest": "/api/health.ts" }
  ]
}
