{
  "framework": null,
  "buildCommand": "npx prisma generate",
  "outputDirectory": ".",
  "regions": ["sin1"],
  "rewrites": [
    { "source": "/graphql", "destination": "/api/graphql" },
    { "source": "/health", "destination": "/api/health" }
  ],
  "crons": [
    { "path": "/api/cron-sync?channel=airbnb",      "schedule": "0 1 * * *" },
    { "path": "/api/cron-sync?channel=gathern",     "schedule": "0 2 * * *" },
    { "path": "/api/cron-sync?channel=booking.com", "schedule": "0 3 * * *" }
  ]
}
